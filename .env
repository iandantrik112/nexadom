# =============================================
# NEXA FRAMEWORK ENVIRONMENT CONFIGURATION
# =============================================

# Application Environment
APP_ENV=production             # development|production
APP_DEBUG=true
APP_NAME=NexaDom MVC Framework
APP_VERSION=2.0.0
APP_TIMEZONE=Asia/Jakarta
#APP_URL=http://localhost/project
LOG_FORMAT=text                 # Log format: text or json
LOG_LEVEL=DEBUG                 # Log levels: CRITICAL, ERROR, WARNING, INFO, DEBUG, TRACE
INCLUDE_STACK_TRACE=false       # Include stack trace in logs (true/false)
MAX_LOG_SIZE=10485760           # Maximum log file size in bytes (10MB)
MAX_LOG_FILES=7                 # Maximum number of log files to keep

NEXA_SECRET_KEY=NEXA-TATIYE

# Database Configuration
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=nexa02
DB_USERNAME=root
DB_PASSWORD=12345678


# Session Configuration 86400 1 Hari 604800 7 Hari
SESSION_DRIVER=file
SESSION_LIFETIME=604800 
SESSION_SECURE=false
SESSION_HTTPONLY=true
SESSION_SAMESITE=lax

# Mail Configuration (Optional)
MAIL_DRIVER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@nexadom.com
MAIL_FROM_NAME="NexaDom Framework"

