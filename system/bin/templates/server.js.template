const express = require('express');
const path = require('path');
const fs = require('fs');
const { createProxyMiddleware } = require('http-proxy-middleware');
const cors = require('cors');
const app = express();

// Try to load sharp for image processing (optional)
let sharp;
try {
  sharp = require('sharp');
} catch (e) {
  console.log('[INFO] Sharp not installed - image resize disabled');
  console.log('[INFO] Install with: npm install sharp');
}

// Port configuration
const PORT = process.env.PORT || 3000;

function resolvePhpServer() {
  const ignoreFile = process.env.NEXA_IGNORE_PHP_PORT_FILE === '1';
  if (!ignoreFile) {
    try {
      const portFile = path.join(__dirname, '.nexa-php-port');
      if (fs.existsSync(portFile)) {
        const raw = fs.readFileSync(portFile, 'utf8').trim();
        const port = raw.replace(/^\uFEFF/, '').split(/\r?\n/)[0].trim();
        if (/^\d{1,5}$/.test(port)) {
          const n = parseInt(port, 10);
          if (n >= 1 && n <= 65535) {
            return `http://127.0.0.1:${n}`;
          }
        }
      }
    } catch (_) {
      /* ignore */
    }
  }
  if (process.env.PHP_SERVER) {
    return process.env.PHP_SERVER;
  }
  return 'http://127.0.0.1:8000';
}

const PHP_SERVER = resolvePhpServer();

// Middleware
app.use(cors()); // Enable CORS for all origins
app.use(express.json());
app.use(express.urlencoded({ extended: true }));

// Image resize endpoint: /drive/{width}x{height}/{path}
// Example: /drive/500x300/2026/03/image.png
app.get('/drive/:size(\\d+x\\d+)/:path(*)', async (req, res) => {
  if (!sharp) {
    return res.status(501).json({ 
      error: 'Image resize not available',
      message: 'Install sharp: npm install sharp'
    });
  }

  try {
    const [width, height] = req.params.size.split('x').map(Number);
    const imagePath = path.join(__dirname, 'assets', 'drive', req.params.path);

    // Security: prevent directory traversal
    const realPath = fs.realpathSync(imagePath);
    const basePath = fs.realpathSync(path.join(__dirname, 'assets', 'drive'));
    if (!realPath.startsWith(basePath)) {
      return res.status(403).send('Forbidden');
    }

    // Check if file exists
    if (!fs.existsSync(realPath)) {
      return res.status(404).send('Image not found');
    }

    // Validate dimensions
    if (width > 5000 || height > 5000) {
      return res.status(400).json({ error: 'Dimensions too large (max 5000x5000)' });
    }

    // Resize image with sharp
    const resizedImage = await sharp(realPath)
      .resize(width, height, {
        fit: 'cover',
        position: 'center'
      })
      .toBuffer();

    // Set cache headers
    res.set({
      'Content-Type': `image/${path.extname(realPath).slice(1)}`,
      'Cache-Control': 'public, max-age=2592000', // 30 days
      'ETag': `"${width}x${height}-${path.basename(realPath)}"`
    });

    res.send(resizedImage);
  } catch (error) {
    console.error('[Resize Error]', error);
    res.status(500).json({ error: 'Image resize failed', message: error.message });
  }
});

// Static files - serve from assets/drive as /drive (original size)
app.use('/drive', express.static(path.join(__dirname, 'assets', 'drive')));

// Proxy untuk PHP API Controllers (NexaUI)
// Semua request ke /nx/* akan diteruskan ke PHP server
app.use('/nx', createProxyMiddleware({
  target: PHP_SERVER,
  changeOrigin: true,
  pathRewrite: {
    '^/nx': '/api'
  },
  onProxyReq: (proxyReq, req, res) => {
    const targetUrl = `${PHP_SERVER}${req.url.replace('/nx', '/api')}`;
    console.log(`[Proxy] ${req.method} ${req.url} -> ${targetUrl}`);
    
    // Re-stream parsed body for POST/PUT/PATCH/DELETE requests
    if (req.body && Object.keys(req.body).length > 0) {
      const bodyData = JSON.stringify(req.body);
      proxyReq.setHeader('Content-Type', 'application/json');
      proxyReq.setHeader('Content-Length', Buffer.byteLength(bodyData));
      proxyReq.write(bodyData);
      console.log(`[Proxy Body] ${bodyData}`);
    }
  },
  onProxyRes: (proxyRes, req, res) => {
    console.log(`[Proxy Response] ${proxyRes.statusCode} ${req.method} ${req.url}`);
  },
  onError: (err, req, res) => {
    console.error('[Proxy Error]', err.message);
    const refused = err.code === 'ECONNREFUSED' || /ECONNREFUSED/i.test(String(err.message));
    const hint = refused
      ? 'Jalankan PHP di port yang sama: nexa dev (satu perintah) atau terminal lain: nexa start 8001 1. Pastikan tidak ada proses lain yang memakai port itu.'
      : '';
    if (!res.headersSent) {
      res.status(502).json({
        error: 'PHP server proxy error',
        message: err.message,
        code: err.code,
        phpServer: PHP_SERVER,
        hint
      });
    }
  }
}));

// Node.js API Routes (native)
app.get('/api/health', (req, res) => {
  res.json({ 
    status: 'ok', 
    message: 'NexaUI Node.js server is running',
    timestamp: new Date().toISOString(),
    phpServer: PHP_SERVER
  });
});

// Example API endpoint
app.get('/api/test', (req, res) => {
  res.json({ 
    message: 'Test endpoint working',
    data: {
      framework: 'NexaUI',
      server: 'Node.js + Express',
      phpProxy: `Use /nx/* to access PHP controllers`
    }
  });
});

// Test non-blocking - slow endpoint
app.get('/api/slow', async (req, res) => {
  const start = Date.now();
  // Simulate slow operation (5 seconds)
  await new Promise(resolve => setTimeout(resolve, 5000));
  const elapsed = Date.now() - start;
  
  res.json({
    message: 'Slow endpoint completed',
    elapsed: `${elapsed}ms`,
    note: 'Other requests were processed during this wait!'
  });
});

// Test non-blocking - fast endpoint
app.get('/api/fast', (req, res) => {
  res.json({
    message: 'Fast endpoint',
    timestamp: Date.now(),
    note: 'This responds immediately even if /api/slow is running'
  });
});

// Start server
app.listen(PORT, () => {
  console.log('');
  console.log('  ╔═══════════════════════════════════════╗');
  console.log('  ║   NexaUI — Node.js Server Running    ║');
  console.log('  ╚═══════════════════════════════════════╝');
  console.log('');
  console.log(`  🚀 Server: http://localhost:${PORT}`);
  console.log(`  📊 Health: http://localhost:${PORT}/api/health`);
  console.log('');
  console.log('  Press Ctrl+C to stop');
  console.log('');
});

// Graceful shutdown
process.on('SIGTERM', () => {
  console.log('\n  Server shutting down gracefully...');
  process.exit(0);
});

process.on('SIGINT', () => {
  console.log('\n  Server shutting down gracefully...');
  process.exit(0);
});
